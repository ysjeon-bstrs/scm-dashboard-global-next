NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ALLOWED_DOMAIN=example.com
NEXT_PUBLIC_API_PREFIX=/api

# Supabase table names for your own schema.
SCM_INVENTORY_SNAPSHOT_TABLE=
SCM_LOGISTICS_MOVES_TABLE=

# Optional source database for server-side adapters. Never expose these to the browser.
SCM_SOURCE_DB_HOST=
SCM_SOURCE_DB_PORT=3306
SCM_SOURCE_DB_DATABASE=
SCM_SOURCE_DB_USER=
SCM_SOURCE_DB_PASSWORD=
SCM_SOURCE_CJ_STOCK_TABLE=
SCM_SOURCE_STOCK_TABLE=
SCM_SOURCE_MOVES_TABLE=

# Optional domestic/Nansoft stock source DB for 디자인KR ETL. Never expose these to the browser.
# Defaults to the same host/user as BOOSTERS_CREW_MYSQL_* and database `boosters` when unset.
DOMESTIC_SOURCE_DB_HOST=
DOMESTIC_SOURCE_DB_PORT=3306
DOMESTIC_SOURCE_DB_DATABASE=boosters
DOMESTIC_SOURCE_DB_USER=
DOMESTIC_SOURCE_DB_PASSWORD=

# Optional Amazon raw source DB for code-owned ETL tests. Never expose these to the browser.
BOOSTERS_CREW_MYSQL_HOST=
BOOSTERS_CREW_MYSQL_PORT=3306
BOOSTERS_CREW_MYSQL_DATABASE=boosters_crew
BOOSTERS_CREW_MYSQL_USER=
BOOSTERS_CREW_MYSQL_PASSWORD=

# Optional. Only expose this if your AG Grid license policy allows browser use.
NEXT_PUBLIC_AG_GRID_LICENSE_KEY=

# Keep server-only secrets out of the browser.
SUPABASE_SERVICE_ROLE_KEY=

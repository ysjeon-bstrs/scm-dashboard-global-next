NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_ALLOWED_DOMAIN=example.com
NEXT_PUBLIC_API_PREFIX=/api

# Supabase table names for your own schema.
SCM_INVENTORY_SNAPSHOT_TABLE=
SCM_LOGISTICS_MOVES_TABLE=

# Optional source database for server-side adapters. Never expose these to the browser.
SCM_SOURCE_DB_HOST=
SCM_SOURCE_DB_PORT=3306
SCM_SOURCE_DB_DATABASE=
SCM_SOURCE_DB_USER=
SCM_SOURCE_DB_PASSWORD=
SCM_SOURCE_CJ_STOCK_TABLE=
SCM_SOURCE_STOCK_TABLE=
SCM_SOURCE_MOVES_TABLE=

# Optional. Only expose this if your AG Grid license policy allows browser use.
NEXT_PUBLIC_AG_GRID_LICENSE_KEY=

# Keep server-only secrets out of the browser.
SUPABASE_SERVICE_ROLE_KEY=
